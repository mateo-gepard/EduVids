# ════════════════════════════════════════════════════════════════
# EduVid AI — Environment Configuration
# Copy this file to .env and fill in your API keys
# ════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173
MAX_CONCURRENT_PIPELINES=2

# ── Authentication (Optional) ──────────────────────────────────
# When set, all API requests must include header: X-API-Key: <your-key>
# Leave empty to disable authentication (development only!)
API_KEY=

# ── LLM Provider ───────────────────────────────────────────────
# Options: "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini (alternative)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Whisper STT model
WHISPER_MODEL=whisper-1

# ── Text-to-Speech ─────────────────────────────────────────────
# Priority: ElevenLabs → OpenAI TTS → Google TTS (unofficial)
# ElevenLabs (recommended for production — high quality voices)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# OpenAI TTS uses OPENAI_API_KEY above (no extra config needed)

# ── Google APIs ────────────────────────────────────────────────
# Google Custom Search (for infographic image search)
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# Google Cloud Vision (for OCR on infographic images)
GOOGLE_CLOUD_VISION_KEY=

# ── Paths ──────────────────────────────────────────────────────
OUTPUT_DIR=./output
TMP_DIR=./tmp

# ── Feature Flags ──────────────────────────────────────────────
# Set to "true" to skip all real API calls (returns mock data)
MOCK_MODE=false
