{
	"version": 2,
	"builds": [
		{
			"src": "api/[...path].js",
			"use": "@vercel/node"
		},
		{
			"src": "src/client/**",
			"use": "@vercel/static"
		},
		{
			"src": "src/client/public/**",
			"use": "@vercel/static"
		}
	],
	"routes": [
		{
			"src": "/api/(.*)",
			"dest": "api/[...path].js"
		},
		{
			"src": "/favicon.svg",
			"dest": "/src/client/public/favicon.svg"
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/src/client/index.html"
		}
	]
}
